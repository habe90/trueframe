#!/usr/bin/env php
<?php

/**
 * TrueFrame CLI
 *
 * Entry point for all trueframe commands.
 * Run `php trueframe help` to see available commands.
 */

// Autoload Composer dependencies
require __DIR__.'/vendor/autoload.php';

// Load the application instance
$app = require_once __DIR__.'/bootstrap/app.php';

// Resolve the console application and run it
$console = $app->make(TrueFrame\Console\Application::class);

// Register app-level commands via the console kernel
$kernel = new App\Console\Kernel($app);
$kernel->registerCommands($console);

// Pass command line arguments, excluding the script name itself
exit($console->run(array_slice($argv, 1)));